# ===== OpenRouter AI provider =====
# Get an API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The model the whole app uses. Swap this value to change models app-wide —
# no code changes required (e.g. anthropic/claude-3.7-sonnet, openai/gpt-5, google/gemini-2.5-pro).
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Optional — sensible defaults are used if omitted.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=2

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Itinera

# ===== Google Maps Platform =====
# Create a key at https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Maps JavaScript API, Places API (New), Routes API, Geocoding API.
# Restrict the key by HTTP referrer for production.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Map ID (required for Advanced Markers & cloud styling). "DEMO_MAP_ID"
# works for local development. https://console.cloud.google.com/google/maps-apis/studio/maps
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Routing: the browser uses the Directions API (enable it for the referrer-restricted
# key above). Alternatively, set a SEPARATE server key (IP-restricted, no referrer
# restriction) to use the server-side Routes API proxy instead.
# GOOGLE_MAPS_SERVER_API_KEY=

# ===== Destination search (GeoNames) =====
# Optional. Register a free username at https://www.geonames.org/login and enable
# web services. With it, the city picker suggests popular cities by population.
# Without it, the app falls back to free keyless geocoding (Open-Meteo) for typed
# city search and seeds each country's capital. No country/city data is stored in
# the database — only the destinations the user selects.
GEONAMES_USERNAME=

# ===== Supabase (favorites + itinerary persistence) =====
# Project URL and publishable (anon) key. Safe to expose to the browser.
# Without these the app persists to localStorage instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
