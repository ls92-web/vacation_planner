# ===== OpenRouter AI provider =====
# Get an API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The model the whole app uses. Swap this value to change models app-wide —
# no code changes required (e.g. anthropic/claude-3.7-sonnet, openai/gpt-5, google/gemini-2.5-pro).
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Optional — sensible defaults are used if omitted.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=2

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Wanderfold

# ===== Google Maps Platform =====
# Create a key at https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Maps JavaScript API, Places API (New), Routes API, Geocoding API.
# Restrict the key by HTTP referrer for production.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Map ID (required for Advanced Markers & cloud styling). "DEMO_MAP_ID"
# works for local development. https://console.cloud.google.com/google/maps-apis/studio/maps
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
